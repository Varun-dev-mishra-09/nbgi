{
  "name": "ngbi-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "npm --workspace apps/user run dev",
    "dev:conductor": "npm --workspace apps/conductor run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
